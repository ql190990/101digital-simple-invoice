# ─────────────────────────────────────────────────────────────────────────────
# SimpleInvoice — environment reference. Copy to `.env` and fill values.
# No real secrets belong in this file or in the codebase.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
POSTGRES_USER=simpleinvoice
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=simpleinvoice
POSTGRES_PORT=5432

# Connection string consumed by Prisma in the backend.
# When running the backend on the host (without Docker), host is localhost.
# Inside docker-compose the backend overrides host to the "db" service name.
DATABASE_URL=postgresql://simpleinvoice:change_me_in_local_env@localhost:5432/simpleinvoice?schema=public

# ── Backend API ──────────────────────────────────────────────────────────────
BACKEND_PORT=3000
NODE_ENV=development

# JWT — MUST be a long random string in any real deployment.
JWT_SECRET=change_me_to_a_long_random_string
# Access-token TTL in seconds (spec default 3600).
JWT_EXPIRES_IN=3600

# Timezone used for date-only "today" comparisons (Overdue derivation). Default UTC.
APP_TIMEZONE=UTC

# Comma-separated CORS allow-list (used when the SPA is not proxied via nginx).
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Max page size clamp for GET /invoices pagination.
MAX_PAGE_SIZE=100

# Login rate limiting (requests per TTL window, TTL in seconds).
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Run migrations + seed automatically on backend boot (used in docker-compose).
SEED_ON_BOOT=false

# Default seeded reviewer account (documented in README).
SEED_USER_EMAIL=reviewer@101digital.io
SEED_USER_PASSWORD=Password123!
SEED_USER_FULLNAME=Reviewer

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=8080
# Base URL for API calls. In Docker this is "/api" (nginx proxies to backend).
# For host dev, Vite proxies /api to http://localhost:3000 (see vite.config.ts).
VITE_API_BASE_URL=/api
